# SportAPI Configuration (RapidAPI) - for Head-to-Head data
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=sportapi7.p.rapidapi.com

# Football-Data.org API - for league standings, fixtures, results, top scorers, lineups
# Get your free API key from: https://www.football-data.org/
# Sign up → Go to your account → Copy your API token
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# JWT Secret for user authentication (REQUIRED - must be at least 32 characters)
# Generate a random secure string for production
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long

# WordPress API Configuration
NEXT_PUBLIC_WP_API_URL=https://sureodds.ng/wp-json/wp/v2
NEXT_PUBLIC_WP_API=https://sureodds.ng/wp-json/wp/v2

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://sureodds.ng
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paystack Configuration (for subscription payments)
# Get your keys from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# Email Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
# Sign up for free at https://resend.com
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@sureodds.ng
ADMIN_EMAIL=admin@sureodds.ng
