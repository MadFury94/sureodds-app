# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# WordPress REST API base URL
NEXT_PUBLIC_WP_API=https://yourdomain.com/wp-json/wp/v2

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Football Data API key — get from football-data.org
FOOTBALL_DATA_API_KEY=

# WordPress JWT auth secret — must match wp-config.php define('JWT_AUTH_SECRET_KEY', ...)
JWT_AUTH_SECRET_KEY=

# User auth JWT secret — min 32 random characters
JWT_SECRET=

# Paystack — get from dashboard.paystack.com
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Resend email — get from resend.com
RESEND_API_KEY=
ADMIN_EMAIL=admin@yourdomain.com
FROM_EMAIL=noreply@yourdomain.com

# Google AdSense — get from adsense.google.com
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUB_ID=

# AdSense slot IDs — create ad units in AdSense dashboard to get these
NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Google Search Console verification token
GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
