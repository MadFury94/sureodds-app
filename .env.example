# ── WordPress API ─────────────────────────────────────────────────────────
NEXT_PUBLIC_WP_API=https://cms.sureodds.ng/wp-json/wp/v2
NEXT_PUBLIC_WP_API_URL=https://cms.sureodds.ng/wp-json/wp/v2
WP_ADMIN_USER=your_wp_admin_email
WP_ADMIN_PASSWORD=your_wp_admin_password

# ── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sureodds.ng
NEXT_PUBLIC_APP_URL=https://sureodds.ng

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long

# ── Google AdSense ────────────────────────────────────────────────────────
# Publisher ID from: https://adsense.google.com → Account → Account information
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX
# Slot IDs from: AdSense → Ads → By ad unit → create units
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_HOME=XXXXXXXXXX

# ── Google Analytics ──────────────────────────────────────────────────────
# From: https://analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google Search Console ─────────────────────────────────────────────────
# From: Search Console → Settings → Ownership verification → HTML tag → content value
GOOGLE_SITE_VERIFICATION=

# ── Payments (Paystack) ───────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@sureodds.ng
ADMIN_EMAIL=admin@sureodds.ng

# ── Sports APIs ───────────────────────────────────────────────────────────
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=sportapi7.p.rapidapi.com
